-- Auto walk (slightly updated to use current group)
local function osnova_find_target_location(origin, now)
    now = now or common.Time()

    -- Pick the spot we're looking at (inside the FOV cone), then only engage
    -- when we're actually standing on/near its ground point. This keeps the
    -- short-range walk/aim behaviour but disambiguates overlapping spots by
    -- where you point, not by which one was created last.
    local loc = osnova_select_target(origin)
    if not loc or not (loc.pos_x and loc.pos_y) then return nil, nil end

    local dx = loc.pos_x - origin.x
    local dy = loc.pos_y - origin.y
    local dist2d = math.sqrt(dx * dx + dy * dy)
    if dist2d > AUTO_WALK_RADIUS then return nil, nil end

    local blocked = loc.no_aim_until and now < loc.no_aim_until
    if blocked then return nil, nil end

    return loc, dist2d
end

-- True while any location is actively replaying a recorded macro.
-- Used to keep the auto-walk / auto-aim from fighting the replayed input,
-- so a macro replays the movement and camera exactly (toch-v-toch).
local function osnova_any_macro_playing()
    for _, md in pairs(ui.map_data) do
        if md.groups then
            for _, grp in pairs(md.groups) do
                for _, l in ipairs(grp.locations or {}) do
                    if l.seq_active and l.macro then return true end
                end
            end
        end
        if md.movement_helpers then
            for _, mh in pairs(md.movement_helpers) do
                for _, l in ipairs(mh.locations or {}) do
                    if l.movement_play_active and l.movement_macro then return true end
                end
            end
        end
    end
    return false
end

local function osnova_auto_walk_to_location()
    osnova_update_helper_active()
    if not ui.settings.active then aw_release(); return end
    local action_locs = osnova_get_action_locations()
    if not action_locs or #action_locs == 0 then aw_release(); return end
    -- don't fight the macro replay: it owns the movement keys now
    if osnova_any_macro_playing() then aw_release(); return end

    local local_player = entities.GetLocalPlayer()
    if not local_player or not local_player:IsAlive() then aw_release(); return end

    if aw_user_is_moving() then
        aw_release()
        return
    end

    local origin = local_player:GetAbsOrigin()
    local target_loc, target_dist = osnova_find_target_location(origin)

    if not target_loc then aw_release(); return end
    if target_dist < AUTO_WALK_STOP_DIST then
        aw_release()
        return
    end

    local view_angles = nil
    pcall(function() view_angles = engine.GetViewAngles() end)
    if not view_angles then
        pcall(function() view_angles = local_player:GetAbsAngles() end)
    end
    view_angles = view_angles or { yaw = 0 }

    local yaw = math.rad(view_angles.yaw or view_angles.y or 0)
    local fx, fy = math.cos(yaw), math.sin(yaw)
    local rx, ry = math.sin(yaw), -math.cos(yaw)

    local dx = target_loc.pos_x - origin.x
    local dy = target_loc.pos_y - origin.y
    local dlen = math.sqrt(dx * dx + dy * dy)
    if dlen < 0.01 then aw_release(); return end
    dx, dy = dx / dlen, dy / dlen

    local rel_forward = dx * fx + dy * fy
    local rel_side = dx * rx + dy * ry

    local function held(prev, val)
        if prev then
            return val > AUTO_WALK_RELEASE_TH
        else
            return val > AUTO_WALK_PRESS_TH
        end
    end

    local press_w = held(AW.prev.w, rel_forward)
    local press_s = held(AW.prev.s, -rel_forward)
    local press_d = held(AW.prev.d, rel_side)
    local press_a = held(AW.prev.a, -rel_side)

    if press_w and press_s then press_s = false end
    if press_a and press_d then press_d = false end

    AW.prev.w, AW.prev.a, AW.prev.s, AW.prev.d = press_w, press_a, press_s, press_d

    local walk_slow = target_dist < AUTO_WALK_SLOW_RADIUS
    aw_set_keys(press_w, press_s, press_a, press_d, walk_slow)
end

callbacks.Register("Draw", "osnova_gh_autowalk", function()
    local ok, err = pcall(osnova_auto_walk_to_location)

end)
