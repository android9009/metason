    pcall(function() print("[OSNOVA GH DEBUG] " .. tostring(msg)) end)
end

local function osnova_debug_database_summary(reason)
    local total = 0
    osnova_debug("database " .. tostring(reason) .. ", current_map=" .. tostring(ui.current_map))
    for map, md in pairs(ui.map_data or {}) do
        local map_total = 0
        if md.groups then
            for def, grp in pairs(md.groups) do
                local c = osnova_count_locations((grp or {}).locations)
                if c > 0 then
                    osnova_debug("  map=" .. tostring(map) .. " group=" .. tostring(def) .. " locations=" .. tostring(c))
                end
                map_total = map_total + c
            end
        end
        if md.movement_helpers then
            for id, mh in pairs(md.movement_helpers) do
                local c = osnova_count_locations((mh or {}).locations)
                if c > 0 then
                    osnova_debug("  map=" .. tostring(map) .. " movement=" .. tostring(id) .. " locations=" .. tostring(c))
                end
                map_total = map_total + c
            end
        end
        if md.wallbang then
            local c = osnova_count_locations(md.wallbang.locations)
            if c > 0 then
                osnova_debug("  map=" .. tostring(map) .. " wallbang locations=" .. tostring(c))
            end
            map_total = map_total + c
        end
        total = total + map_total
    end
    osnova_debug("total locations=" .. tostring(total))
end

local function osnova_count_locations_for_current_view(browser, id)
    if ui.show_all_maps then
        local n = 0
        for map, _ in pairs(ui.map_data) do
            n = n + osnova_count_locations(osnova_get_locations_for(map, browser, id))
        end
        return n
    end
    return osnova_count_locations(osnova_get_locations_for(ui.current_map, browser, id))
end

local function osnova_encode_lua_string(str)
    -- ASCII-only string encoding for the database file.
    -- This avoids UTF-8 / Windows-1251 text encoding issues in Aimware's file API.
    -- Every byte is stored as \DDD, so Cyrillic names and other symbols cannot
    -- break loadstring() or truncate / corrupt every other location.
    str = tostring(str or "")
    local out = { '"' }
    for i = 1, string.len(str) do
        table.insert(out, string.format("\\%03d", string.byte(str, i)))
    end
    table.insert(out, '"')
    return table.concat(out)
end

local function osnova_serialize_value(v, indent)
    indent = indent or 0
    local t = type(v)
    if t == "number" or t == "boolean" then return tostring(v) end
    if t == "string" then return osnova_encode_lua_string(v) end
    if t ~= "table" then return "nil" end
    local pad = string.rep(" ", indent)
    local out = { "{\n" }
    for k, val in pairs(v) do
        local key = type(k) == "number" and ("[" .. k .. "]") or ("[" .. osnova_encode_lua_string(tostring(k)) .. "]")
        table.insert(out, pad .. "  " .. key .. " = " .. osnova_serialize_value(val, indent + 2) .. ",\n")
    end
    table.insert(out, pad .. "}")
    return table.concat(out)
end

