local last_render_time = common.Time()

local function osnova_position_visible(player_origin, world_vec)
    local from = Vector3(player_origin.x, player_origin.y, player_origin.z + 64)
    local tr = nil
    local ok = pcall(function() tr = engine.TraceLine(from, world_vec) end)
    if not ok or not tr then return true end
    if tr.fraction and tr.fraction > 0.97 then return true end
    return false
end

-- 6 trace samples around a saved location. This gives a pseudo-chams style
-- visibility percent: 1.0 = fully visible, 0.0 = fully behind wall, values in
-- between = partially visible. We still draw 2D overlay, so this cannot cut the
-- marker by real map geometry, but it can make partial/hidden spots behave smart.
local VIS_SAMPLE_OFFSETS = {
    { 0, 0, 0 },
    { 0, 0, 42 },
    { 18, 0, 18 },
    { -18, 0, 18 },
    { 0, 18, 18 },
    { 0, -18, 18 },
}

local function osnova_location_visibility_fraction(player_origin, loc)
    if not (loc and loc.pos_x and loc.pos_y and loc.pos_z) then return 0 end

    local visible = 0
    local total = #VIS_SAMPLE_OFFSETS

    for _, o in ipairs(VIS_SAMPLE_OFFSETS) do
        local sample = Vector3(loc.pos_x + o[1], loc.pos_y + o[2], loc.pos_z + o[3])
        if osnova_position_visible(player_origin, sample) then
            visible = visible + 1
        end
    end

    return visible / total
end

-- World-space rendering: locations are clustered on-screen into single boxes,
-- and each qualifying location draws its own aim-point marker.
-- Draw the aim-point marker for a single location (used by clustered rendering)
local function osnova_draw_aim_point(it, player_origin, dt, pulse)
    local loc = it.loc
    local alpha = it.alpha
    local screen_x, screen_y = it.screen_x, it.screen_y
    local is_target = it.is_target

    local aim_vec = Vector3(loc.aim_x, loc.aim_y, loc.aim_z)
    local aim_sx, aim_sy = client.WorldToScreen(aim_vec)

    if not aim_sx or not aim_sy then
        local px, py, pz = loc.pos_x, loc.pos_y, loc.pos_z
        if px and py and pz then
            local ddx = loc.aim_x - px
            local ddy = loc.aim_y - py
            local ddz = loc.aim_z - (pz + 64)
            local ddlen = math.sqrt(ddx*ddx + ddy*ddy + ddz*ddz)
            if ddlen > 0.1 then
                local near_x = px + ddx * 50 / ddlen
                local near_y = py + ddy * 50 / ddlen
                local near_z = pz + 64 + ddz * 50 / ddlen
                local nx, ny = client.WorldToScreen(Vector3(near_x, near_y, near_z))
                if nx and ny then
                    local lsx, lsy = screen_x, screen_y
                    if not lsx or not lsy then
                        local sw, sh = draw.GetScreenSize()
                        lsx, lsy = sw * 0.5, sh * 0.85
                    end
                    local sdx, sdy = nx - lsx, ny - lsy
                    local smag = math.sqrt(sdx*sdx + sdy*sdy)
                    if smag > 0.1 then
                        local sw, sh = draw.GetScreenSize()
                        local mul = (sw + sh) / smag
                        aim_sx = lsx + sdx * mul
                        aim_sy = lsy + sdy * mul
                    end
                end
            end
        end
    end

    if aim_sx and aim_sy then
        local is_aimed = osnova_is_aimed_at(player_origin, aim_vec)

        if loc.aim_anim == nil then loc.aim_anim = 0 end
        local anim_speed = 8
        if is_aimed then
            loc.aim_anim = math.min(1, loc.aim_anim + dt * anim_speed)
        else
            loc.aim_anim = math.max(0, loc.aim_anim - dt * anim_speed)
        end
        local t = loc.aim_anim

        local col_r = lerp(255, 100, t)
        local col_g = 255
        local col_b = lerp(255, 100, t)

        -- the FOV-selected target is drawn a touch bigger so it reads as
        -- the one being aimed at, without any special (yellow) colour
        local ar = 5 + t * 1 + (is_target and 3 or 0)
        local pulse_r = ar + 2 + pulse * 2 * t

        draw.Color(col_r, col_g, col_b, alpha * (0.05 + 0.05 * t))
        draw.OutlinedCircle(aim_sx, aim_sy, pulse_r + 6)
        draw.Color(col_r, col_g, col_b, alpha * (0.08 + 0.08 * t))
        draw.OutlinedCircle(aim_sx, aim_sy, pulse_r + 3)

        draw.Color(col_r, col_g, col_b, alpha * 0.9)
        draw.FilledCircle(aim_sx, aim_sy, ar)
        draw.Color(col_r, col_g, col_b, alpha * 0.5)
        draw.OutlinedCircle(aim_sx, aim_sy, ar + 2)
        draw.Color(col_r, col_g, col_b, alpha * 0.3)
        draw.OutlinedCircle(aim_sx, aim_sy, ar + 3)
        draw.Color(col_r, col_g, col_b, alpha * 0.15)
        draw.OutlinedCircle(aim_sx, aim_sy, ar + 4)

        draw.Color(255, 255, 255, alpha * (0.5 + 0.3 * t))
        draw.FilledCircle(aim_sx, aim_sy, ar * 0.4)

        local aim_label = loc.name or "Location"
        draw.SetFont(f_distance)
        local ltw, lth = draw.GetTextSize(aim_label)

        local pad_x = 10
        local pad_y = 5
        local accent_w = 3
        local box_gap = ar + 8
        local box_x1 = aim_sx + box_gap
        local box_y1 = aim_sy - (lth + pad_y * 2) / 2
        local box_x2 = box_x1 + accent_w + pad_x * 2 + ltw
        local box_y2 = box_y1 + lth + pad_y * 2
        local box_r = 4

        draw.Color(0, 0, 0, alpha * 0.35)
        draw.ShadowRect(box_x1, box_y1, box_x2, box_y2, 10)

        draw.Color(12, 12, 12, alpha * 0.88)
        draw.RoundedRectFill(box_x1, box_y1, box_x2, box_y2, box_r, box_r, box_r, box_r, box_r)

        draw.Color(col_r, col_g, col_b, alpha * 0.6)
        draw.RoundedRect(box_x1, box_y1, box_x2, box_y2, box_r, box_r, box_r, box_r, box_r)

        draw.Color(col_r, col_g, col_b, alpha * 0.9)
        draw.RoundedRectFill(box_x1 + 2, box_y1 + 2, box_x1 + 2 + accent_w, box_y2 - 2, 2, 2, 0, 2, 0)

        draw.Color(255, 255, 255, alpha * (0.85 + 0.15 * t))
        draw.Text(box_x1 + accent_w + pad_x, box_y1 + pad_y, aim_label)
    end
end

-- World-space cluster radius: locations whose ground positions are within
-- this many units are merged into one box. Keep it tight: spots should only
-- merge when they are basically the same place.
local CLUSTER_WORLD_RADIUS = 30
local LOCATION_MAX_RENDER_DISTANCE = 450
local LOCATION_BOX_SHRINK_START = 250
local LOCATION_FADE_START_DISTANCE = 350

-- Updated: cluster nearby on-screen locations into ONE vertical box
-- Screen (crosshair) centre in pixels.
local function osnova_screen_center()
    local w, h = 0, 0
    pcall(function() w, h = draw.GetScreenSize() end)
    if w <= 0 or h <= 0 then w, h = 1920, 1080 end
    return w / 2, h / 2
end

-- FOV-based target selection -- the single source of truth for "which spot
-- am I aiming at". Walks the current active list's saved locations and returns
-- the ONE whose AIM POINT projects closest to the crosshair while still
-- inside the FOV cone (AIM_FOV_PX pixels around screen centre).
-- Grenade mode requires a grenade in hand; Movement Helper mode uses the
-- selected Movement Helper group (Knife for now) and does not require a grenade.
local function osnova_select_target(origin, fov_px)
    fov_px = fov_px or (ui.settings and ui.settings.fov) or AIM_FOV_PX

    local locs = osnova_get_action_locations()
    if not locs or #locs == 0 then return nil end

    local cx, cy = osnova_screen_center()

    local best, best_d = nil, nil
    for _, loc in pairs(locs) do
        if loc.aim_x and loc.aim_y and loc.aim_z then
            local sx, sy = client.WorldToScreen(Vector3(loc.aim_x, loc.aim_y, loc.aim_z))
            if sx and sy then
                local d = math.sqrt((sx - cx) ^ 2 + (sy - cy) ^ 2)
                if d <= fov_px and (not best_d or d < best_d) then
                    best, best_d = loc, d
                end
            end
        end
    end
    return best
end

local function render_world_locations()
    if not ui.show_locations then return end

    local held_def = osnova_canonical_grenade_def(osnova_active_grenade_def())

    local local_player = entities.GetLocalPlayer()
    if not local_player or not local_player:IsAlive() then return end

    local player_origin = local_player:GetAbsOrigin()

    local now = common.Time()
    local dt = now - last_render_time
    if dt < 0 or dt > 0.5 then dt = 0 end
    last_render_time = now
    local pulse = (math.sin(now * 4) + 1) * 0.5

    -- AIM POINTS FIRST: drawn per-location for the selected group when the
    -- player is standing on/near the spot. Done up here (before the ground
    -- marker clustering below) so the reticle + its name box never vanish when
    -- you stand exactly on the location's ground point -- there the ground
    -- marker projects off-screen and would otherwise trip the early return and
    -- skip ALL rendering for this location.
    -- highlight the FOV-selected location so the player can see which spot
    -- is currently armed (the one inside the FOV cone, closest to centre)
    local fov_target = osnova_select_target(player_origin)

    local function draw_near_aim_for_locs(locs, current_icon_id)
        for _, loc in pairs(locs) do
            if loc.aim_x and loc.aim_y and loc.aim_z and loc.pos_x and loc.pos_y and loc.pos_z then
                local pdx = player_origin.x - loc.pos_x
                local pdy = player_origin.y - loc.pos_y
                if math.sqrt(pdx * pdx + pdy * pdy) < 15 then
                    local msx, msy = client.WorldToScreen(Vector3(loc.pos_x, loc.pos_y, loc.pos_z))
                    osnova_draw_aim_point({ loc = loc, alpha = 255, screen_x = msx, screen_y = msy, is_nearby = true, is_target = (loc == fov_target), icon_id = current_icon_id }, player_origin, dt, pulse)
                end
            end
        end
    end

    if ui.selected_browser == "movement" then
        draw_near_aim_for_locs(osnova_get_locations_for(ui.current_map, "movement", ui.selected_movement_helper), nil)
    else
        local render_def = held_def
        if not render_def or not ui.groups[render_def] then
            render_def = ui.selected_group
        end
        if render_def then
            local cdef = osnova_canon_def_early(render_def)
            if osnova_grenade_feature_enabled(cdef) then
                draw_near_aim_for_locs(osnova_get_locations_for(ui.current_map, "group", cdef), cdef)
            end
        end
    end

    -- 1) collect every renderable location with its screen position
    local items = {}

    ui.render_skip_logged = ui.render_skip_logged or {}
    local function log_render_skip(loc, reason)
        -- muted
    end

    local function add_renderable_location(loc, idx, is_selected, icon_id)
        if loc.pos_x and loc.pos_y and loc.pos_z then
            local dx = loc.pos_x - player_origin.x
            local dy = loc.pos_y - player_origin.y
            local dz = loc.pos_z - player_origin.z
            local dist = math.sqrt(dx*dx + dy*dy + dz*dz)
            if dist > LOCATION_MAX_RENDER_DISTANCE then log_render_skip(loc, "too far " .. tostring(math.floor(dist)) .. ">" .. tostring(LOCATION_MAX_RENDER_DISTANCE)); return end

            local alpha = 255
            -- Smooth distance fade before the hard max range, so locations do not
            -- pop out instantly at 450 units. From 350 -> 450 alpha fades 100% -> 0%.
            if dist > LOCATION_FADE_START_DISTANCE then
                local fade = 1 - ((dist - LOCATION_FADE_START_DISTANCE) / (LOCATION_MAX_RENDER_DISTANCE - LOCATION_FADE_START_DISTANCE))
                if fade < 0 then fade = 0 elseif fade > 1 then fade = 1 end
                alpha = alpha * fade
            end

            local player_dist_2d = math.sqrt(
                (player_origin.x - loc.pos_x) ^ 2 + (player_origin.y - loc.pos_y) ^ 2
            )
            local is_nearby = player_dist_2d < 15

            local world_vec = Vector3(loc.pos_x, loc.pos_y, loc.pos_z)
            local screen_x, screen_y = client.WorldToScreen(world_vec)

            local through_walls = ui.visual_features and ui.visual_features.through_walls
            local center_visible = osnova_position_visible(player_origin, world_vec)
            local vis_fraction = osnova_location_visibility_fraction(player_origin, loc) -- 6 samples
            local is_visible = center_visible

            if through_walls then
                local wall_radius = 250

                if vis_fraction >= 0.99 then
                    -- fully visible: no transparency
                    is_visible = true
                elseif dist <= wall_radius then
                    -- Old through-wall behaviour: hidden/partial location is shown in
                    -- radius and fades by distance. 6 highlight samples additionally
                    -- affect alpha, so partially visible spots are clearer than fully
                    -- hidden ones.
                    local closeness = 1 - (dist / wall_radius)
                    if closeness < 0 then closeness = 0 elseif closeness > 1 then closeness = 1 end

                    local visibility_factor = vis_fraction
                    if closeness > visibility_factor then visibility_factor = closeness end

                    -- Minimum alpha is 25% (75% transparent), max is 100%.
                    local alpha_mul = 0.25 + 0.75 * visibility_factor
                    alpha = alpha * alpha_mul
                    is_visible = true
                elseif vis_fraction > 0 then
                    -- Outside through-wall radius: only truly visible sampled parts keep
                    -- the marker alive, using the 6-sample highlight transparency.
                    local alpha_mul = 0.25 + 0.75 * vis_fraction
                    alpha = alpha * alpha_mul
                    is_visible = true
                end
            end

            if alpha >= 5 and screen_x and screen_y and is_visible then
                table.insert(items, {
                    loc = loc, idx = idx,
                    wx = loc.pos_x, wy = loc.pos_y, wz = loc.pos_z,
                    screen_x = screen_x, screen_y = screen_y,
                    dist = dist, alpha = alpha,
                    is_nearby = is_nearby, is_selected = is_selected, icon_id = icon_id
                })
            else
                if not screen_x or not screen_y then
                    log_render_skip(loc, "WorldToScreen failed/offscreen")
                elseif alpha < 5 then
                    log_render_skip(loc, "alpha too low " .. tostring(math.floor(alpha)))
                elseif not is_visible then
                    log_render_skip(loc, "hidden by wall/visibility")
                else
                    log_render_skip(loc, "unknown render filter")
                end
            end
        else
            log_render_skip(loc, "missing pos_x/pos_y/pos_z")
        end
    end

    if ui.show_all_maps then
        for map, _ in pairs(ui.map_data) do
            if ui.selected_browser == "movement" then
                if osnova_movement_feature_enabled() then
                    local locs = osnova_get_locations_for(map, "movement", ui.selected_movement_helper)
                    for i, loc in pairs(locs) do
                        add_renderable_location(loc, i, map == ui.current_map and ui.selected_location == i, nil)
                    end
                end
            else
                -- Show all grenade-group locations from every map. Rendering is visual
                -- only; gameplay still uses the held grenade. This avoids loaded
                -- locations being present in file/menu but invisible in world.
                local render_def = held_def
                if not render_def or not ui.groups[render_def] then
                    render_def = ui.selected_group
                end
                if render_def then
                    local cdef = osnova_canon_def_early(render_def)
                    if osnova_grenade_feature_enabled(cdef) then
                        local locs = osnova_get_locations_for(map, "group", cdef)
                        for i, loc in pairs(locs) do
                            add_renderable_location(loc, i, map == ui.current_map and ui.selected_location == i, cdef)
                        end
                    end
                end
            end
        end
    elseif ui.selected_browser == "movement" then
        if not osnova_movement_feature_enabled() then return end
        local locs = osnova_get_locations_for(ui.current_map, "movement", ui.selected_movement_helper)
        for i, loc in pairs(locs) do
            add_renderable_location(loc, i, ui.selected_location == i, nil)
        end
    else
        -- Render all grenade-group locations on current map. Gameplay still uses
        -- held grenade via osnova_get_action_locations(), but visuals should not
        -- disappear after Lua reload just because UI/held group differ.
        local render_def = held_def
        if not render_def or not ui.groups[render_def] then
            render_def = ui.selected_group
        end
        if render_def then
            local cdef = osnova_canon_def_early(render_def)
            if osnova_grenade_feature_enabled(cdef) then
                local locs = osnova_get_locations_for(ui.current_map, "group", cdef)
                for i, loc in pairs(locs) do
                    add_renderable_location(loc, i, ui.selected_location == i, cdef)
                end
            end
        end
    end

    if #items == 0 then return end

    -- 2) Cluster only when EVERY location inside the cluster is within
    -- CLUSTER_WORLD_RADIUS (30 units) from the new one. Do NOT use union-find:
    -- union-find creates chain merges (A close to B, B close to C) and can merge
    -- A with C even when A-C distance is much bigger than 30.
    local clusters = {}
    local wr2 = CLUSTER_WORLD_RADIUS * CLUSTER_WORLD_RADIUS

    local function world_dist_sqr(a, b)
        local wdx = a.wx - b.wx
        local wdy = a.wy - b.wy
        local wdz = a.wz - b.wz
        return wdx * wdx + wdy * wdy + wdz * wdz
    end

    for _, it in ipairs(items) do
        local added = false

        for _, cluster in ipairs(clusters) do
            local can_add = true

            for _, other in ipairs(cluster) do
                if world_dist_sqr(it, other) > wr2 then
                    can_add = false
                    break
                end
            end

            if can_add then
                table.insert(cluster, it)
                added = true
                break
            end
        end

        if not added then
            table.insert(clusters, { it })
        end
    end

    -- 3) draw each cluster as one dot + one growing vertical box
    for _, cluster in pairs(clusters) do
        local cx, cy = 0, 0
        local has_nearby = false
        local has_selected = false
        local cluster_alpha = 255
        local cluster_dist = 999999
        for _, it in ipairs(cluster) do
            cx = cx + it.screen_x
            cy = cy + it.screen_y
            if it.is_nearby then has_nearby = true end
            if it.is_selected then has_selected = true end
            if it.alpha < cluster_alpha then cluster_alpha = it.alpha end
            if it.dist and it.dist < cluster_dist then cluster_dist = it.dist end
        end
        cx = cx / #cluster
        cy = cy / #cluster

        local far_t = 0
        if cluster_dist > LOCATION_BOX_SHRINK_START then
            far_t = math.min(1, (cluster_dist - LOCATION_BOX_SHRINK_START) / (LOCATION_MAX_RENDER_DISTANCE - LOCATION_BOX_SHRINK_START))
        end

        -- Smooth box scaling / line hiding animation. Without this the box size
        -- and amount of shown locations jumps when crossing 250/450 distance.
        ui.cluster_anims = ui.cluster_anims or {}
        local cluster_key = ""
        for _, it in ipairs(cluster) do
            cluster_key = cluster_key .. tostring(it.loc) .. ";"
        end

        local density_t = 0
        if #cluster > 3 then density_t = math.min(1, (#cluster - 3) / 6) end

        local target_box_scale = 1 - 0.55 * far_t - 0.10 * density_t * far_t
        if target_box_scale < 0.38 then target_box_scale = 0.38 end

        local target_line_limit = #cluster
        if far_t > 0 then
            target_line_limit = math.max(1, 5 - 4 * far_t - 2 * density_t * far_t)
            if target_line_limit > #cluster then target_line_limit = #cluster end
        end

        local anim = ui.cluster_anims[cluster_key]
        if not anim then
            anim = { scale = target_box_scale, line_limit = target_line_limit }
            ui.cluster_anims[cluster_key] = anim
        end

        local anim_t = math.min(1, dt * 8)
        anim.scale = lerp(anim.scale, target_box_scale, anim_t)
        anim.line_limit = lerp(anim.line_limit, target_line_limit, anim_t)

        local box_scale = anim.scale
        local max_visible_lines_float = anim.line_limit

        local mr = 5 * box_scale

        -- colour: brighter white when this cluster holds the selected
        -- location, dimmer white otherwise (no gold)
        local cr, cg, cb = 170, 170, 170
        if has_selected then cr, cg, cb = 255, 255, 255 end

        -- marker rings (same layered look as the aim point)
        local pulse_r = mr + 2 + pulse * 2 * 0.5
        draw.Color(cr, cg, cb, cluster_alpha * 0.10)
        draw.OutlinedCircle(cx, cy, pulse_r + 6)
        draw.Color(cr, cg, cb, cluster_alpha * 0.15)
        draw.OutlinedCircle(cx, cy, pulse_r + 3)
        draw.Color(cr, cg, cb, cluster_alpha * 0.9)
        draw.FilledCircle(cx, cy, mr)
        draw.Color(cr, cg, cb, cluster_alpha * 0.5)
        draw.OutlinedCircle(cx, cy, mr + 2)
        draw.Color(cr, cg, cb, cluster_alpha * 0.3)
        draw.OutlinedCircle(cx, cy, mr + 3)
        draw.Color(cr, cg, cb, cluster_alpha * 0.15)
        draw.OutlinedCircle(cx, cy, mr + 4)
        draw.Color(255, 255, 255, cluster_alpha * 0.6)
        draw.FilledCircle(cx, cy, mr * 0.4)

        -- measure each name (+ distance) line so the box can grow vertically.
        -- Past 250 units the box gets smaller and the extra lines fade out,
        -- then collapse into a +N more line.
        local lines = {}
        local max_w = 0
        local line_font = (box_scale < 0.82) and f_bind or f_location

        local full_lines = math.floor(max_visible_lines_float)
        if full_lines < 1 then full_lines = 1 end
        local partial_line_alpha = max_visible_lines_float - full_lines
        local draw_until = math.min(#cluster, full_lines + (partial_line_alpha > 0.05 and 1 or 0))
        local hidden_count = math.max(0, #cluster - full_lines)

        for idx, it in ipairs(cluster) do
            if idx > draw_until then break end
            local name = it.loc.name or "Location"
            if box_scale < 0.82 and string.len(name) > 18 then
                name = string.sub(name, 1, 16) .. ".."
            end
            draw.SetFont(line_font)
            local nw = draw.GetTextSize(name)
            local dist_str = ""
            local dw = 0
            local icon_w = 0
            if it.icon_id and _G.GH_ICONS.cache[it.icon_id] then
                icon_w = math.floor(_G.GH_ICONS.cache[it.icon_id].width * (box_scale or 1) * 0.65) + 5
            end

            local line_w = icon_w + nw + (dw > 0 and (dw + 10) or 0)
            if line_w > max_w then max_w = line_w end

            local line_alpha = 1
            if idx == full_lines + 1 then
                line_alpha = partial_line_alpha
            end

            table.insert(lines, { name = name, dist = dist_str, dist_w = dw, sel = it.is_selected, more = false, alpha = line_alpha, icon_id = it.icon_id })
        end

        local more_alpha = 0
        if hidden_count > 0 then
            more_alpha = 1 - partial_line_alpha
            if more_alpha < 0 then more_alpha = 0 elseif more_alpha > 1 then more_alpha = 1 end
            local more_name = "+" .. tostring(hidden_count) .. " more"
            draw.SetFont(f_bind)
            local mw = draw.GetTextSize(more_name)
            if mw > max_w then max_w = mw end
            table.insert(lines, { name = more_name, dist = "", dist_w = 0, sel = false, more = true, alpha = more_alpha })
        end

        local line_h = math.floor(17 * box_scale)
        if line_h < 12 then line_h = 12 end
        local pad_x = math.floor(10 * box_scale)
        if pad_x < 6 then pad_x = 6 end
        local pad_y = math.floor(6 * box_scale)
        if pad_y < 4 then pad_y = 4 end
        local accent_w = math.max(2, math.floor(3 * box_scale))
        local box_x = cx + mr + 6 * box_scale
        local box_w = max_w + pad_x * 2 + accent_w
        local visual_lines = math.min(#cluster, max_visible_lines_float) + (hidden_count > 0 and more_alpha or 0)
        if visual_lines < 1 then visual_lines = 1 end
        local box_h = visual_lines * line_h + pad_y * 2
        local box_y = cy - box_h / 2

        local box_x2 = box_x + box_w
        local box_y2 = box_y + box_h
        local box_r = 4

        -- name box: rounded, same look as the aim-point label
        draw.Color(0, 0, 0, cluster_alpha * 0.35)
        draw.ShadowRect(box_x, box_y, box_x2, box_y2, 10)

        draw.Color(12, 12, 12, cluster_alpha * 0.88)
        draw.RoundedRectFill(box_x, box_y, box_x2, box_y2, box_r, box_r, box_r, box_r, box_r)

        draw.Color(cr, cg, cb, cluster_alpha * 0.6)
        draw.RoundedRect(box_x, box_y, box_x2, box_y2, box_r, box_r, box_r, box_r, box_r)

        draw.Color(cr, cg, cb, cluster_alpha * 0.9)
        draw.RoundedRectFill(box_x + 2, box_y + 2, box_x + 2 + accent_w, box_y2 - 2, 2, 2, 0, 2, 0)

        for j, ln in ipairs(lines) do
            local line_alpha = ln.alpha or 1
            if line_alpha > 0.03 then
                local ly = box_y + pad_y + (j - 1) * line_h
                draw.SetFont(ln.more and f_bind or line_font)
                if ln.more then
                    draw.Color(125, 125, 125, cluster_alpha * 0.85 * line_alpha)
                elseif ln.sel then
                    draw.Color(255, 255, 255, cluster_alpha * line_alpha)
                else
                    draw.Color(170, 170, 170, cluster_alpha * line_alpha)
                end
                local text_x = box_x + accent_w + pad_x
                if ln.icon_id and _G.GH_ICONS.cache[ln.icon_id] then
                    local tex = _G.GH_ICONS.cache[ln.icon_id]
                    local tex_w = math.floor(tex.width * box_scale * 0.65)
                    local tex_h = math.floor(tex.height * box_scale * 0.65)
                    local tex_y = ly + (line_h - tex_h) / 2
                    
                    if ln.sel then
                        draw.Color(255, 255, 255, cluster_alpha * line_alpha)
                    else
                        draw.Color(170, 170, 170, cluster_alpha * line_alpha)
                    end
                    draw.SetTexture(tex.texture)
                    draw.FilledRect(text_x, tex_y, text_x + tex_w, tex_y + tex_h)
                    draw.SetTexture(nil)
                    
                    text_x = text_x + tex_w + 5
                end
                draw.Text(text_x, ly + math.max(1, math.floor(2 * box_scale)), ln.name)

                if ln.dist ~= "" then
                    draw.SetFont(f_distance)
                    draw.Color(255, 160, 0, cluster_alpha * line_alpha)
                    draw.Text(box_x + box_w - pad_x - ln.dist_w, ly + 3, ln.dist)
                end
            end
        end

        if has_nearby then
            draw.SetFont(f_distance)
            draw.Color(255, 255, 255, cluster_alpha * 0.7)
            local shw = draw.GetTextSize("STAND HERE")
            draw.Text(cx - shw / 2, cy + mr + 12, "STAND HERE")
        end

    end

    -- FOV cone visualisation: a faint circle of radius AIM_FOV_PX around
    -- the crosshair. A location's aim point must fall inside this ring to
    -- be eligible for auto-aim / auto-walk / playback.
    if ui.settings.active and ((osnova_is_holding_grenade() and osnova_grenade_feature_enabled(ui.selected_group)) or (ui.selected_browser == "movement" and osnova_movement_feature_enabled())) then
        local fov = (ui.settings and ui.settings.fov) or AIM_FOV_PX
        local sw, sh = draw.GetScreenSize()
        if sw > 0 and sh > 0 then
            draw.Color(255, 255, 255, 40)
            draw.OutlinedCircle(sw / 2, sh / 2, fov)
            draw.Color(255, 255, 255, 18)
            draw.OutlinedCircle(sw / 2, sh / 2, fov - 2)
        end
    end
end




-- ==================== WALLBANG HELPER UI / DATA ====================
local WALLBANG_DEFAULT_MAPS = {
    "de_mirage", "de_inferno", "de_dust2", "de_nuke", "de_ancient", "de_anubis",
    "de_overpass", "de_vertigo", "de_train", "de_cache", "de_cbble"
}

local function osnova_wb_locations(map)
    map = osnova_normalize_map_name(map or ui.wallbang.selected_map or ui.current_map)
    local md = osnova_ensure_map_data(map)
    md.wallbang = md.wallbang or { locations = {} }
    md.wallbang.locations = md.wallbang.locations or {}
    return md.wallbang.locations
end

local function osnova_wb_maps()
    local seen, maps = {}, {}
    for _, m in ipairs(WALLBANG_DEFAULT_MAPS) do
        if not seen[m] then seen[m] = true; table.insert(maps, m) end
    end
    for m, _ in pairs(ui.map_data or {}) do
        local nm = osnova_normalize_map_name(m)
        if not seen[nm] then seen[nm] = true; table.insert(maps, nm) end
    end
    table.sort(maps, function(a,b) return tostring(a) < tostring(b) end)
    return maps
end

local function osnova_wb_new_location()
    local locs = osnova_wb_locations(ui.wallbang.selected_map)
    local loc = {
        name = "New Wallbang",
        from_x = nil, from_y = nil, from_z = nil,
        to_x = nil, to_y = nil, to_z = nil,
        step = 1,
    }
    table.insert(locs, loc)
    ui.wallbang.selected_location = #locs
    osnova_save_database()
    return loc
end

local function osnova_wb_current_point()
    local lp = entities.GetLocalPlayer()
    if not lp or not lp:IsAlive() then return nil end
    local o = lp:GetAbsOrigin()
    return o.x, o.y, o.z + 64
end

local function osnova_wb_edit_point()
    local locs = osnova_wb_locations(ui.wallbang.selected_map)
    local loc = locs[ui.wallbang.selected_location]
    if not loc then return end
    local x, y, z = osnova_wb_current_point()
    if not x then return end

    if (not loc.from_x) or loc.step == 1 then
        loc.from_x, loc.from_y, loc.from_z = x, y, z
        loc.step = 2
    else
        loc.to_x, loc.to_y, loc.to_z = x, y, z
        loc.step = 1
    end
    osnova_save_database()
end

local function draw_wb_listbox(x, y, w, h, items, mode)
    draw.Color(13, 13, 13, 255)
    draw.FilledRect(x, y, x + w, y + h)
    draw.Color(unpack(ui.clr.outline))
    draw.OutlinedRect(x, y, x + w, y + h)

    local scroll_key = (mode == "map") and "map_scroll" or "loc_scroll"
    if mouse_in(x, y, w, h) then
        ui.wallbang[scroll_key] = math.max(0, (ui.wallbang[scroll_key] or 0) - input.GetMouseWheelDelta())
    end
    local sc = ui.wallbang[scroll_key] or 0

    for i = sc + 1, #items do
        local iy = y + (i - sc - 1) * 22
        if iy + 22 > y + h then break end
        local hover = mouse_in(x, iy, w, 22)
        local selected = false
        if mode == "map" then
            selected = (ui.wallbang.selected_map == items[i])
        else
            selected = (ui.wallbang.selected_location == i)
        end

        if selected then
            draw.Color(255, 255, 255, 40)
            draw.FilledRect(x + 1, iy + 1, x + w - 1, iy + 21)
            draw.Color(255, 255, 255, 220)
            draw.FilledRect(x + 1, iy + 1, x + 3, iy + 21)
        elseif hover then
            draw.Color(255, 255, 255, 8)
            draw.FilledRect(x + 1, iy + 1, x + w - 1, iy + 21)
        end

        local text = tostring(items[i].name or items[i])
        if mode == "loc" then
            local loc = items[i]
            local state = (loc.from_x and loc.to_x) and " [2/2]" or (loc.from_x and " [1/2]" or " [0/2]")
            text = text .. state
        end
        if selected and ui.renaming and ui.rename_target == "wallbang" and mode == "loc" then
            text = ui.rename_buf .. "_"
        end

        draw.SetFont(f_main)
        draw.Color(selected and 255 or 160, selected and 255 or 160, selected and 255 or 160, 255)
        draw.Text(x + 10, iy + 4, text)

        if hover and input.IsButtonPressed(1) and not ui._combo_blocked then
            if mode == "map" then
                ui.wallbang.selected_map = items[i]
                ui.wallbang.selected_location = 0
                ui.wallbang.loc_scroll = 0
            else
                ui.wallbang.selected_location = i
            end
            ui._combo_blocked = true
        end
    end
end

local function draw_wallbang_tab(cx, cy, cw, ch)
    local gap = 12
    local left_w = math.floor((cw - gap) * 0.42)
    local right_w = cw - left_w - gap
    local lx, rx = cx, cx + left_w + gap

    draw.Color(0, 0, 0, 70)
    draw.ShadowRect(lx, cy, lx + left_w, cy + ch, 10)
    draw.Color(12, 12, 13, 245)
    draw.RoundedRectFill(lx, cy, lx + left_w, cy + ch, 6, 6, 6, 6, 6)
    draw.Color(unpack(ui.clr.outline))
    draw.RoundedRect(lx, cy, lx + left_w, cy + ch, 6, 6, 6, 6, 6)

    draw.Color(0, 0, 0, 70)
    draw.ShadowRect(rx, cy, rx + right_w, cy + ch, 10)
    draw.Color(12, 12, 13, 245)
    draw.RoundedRectFill(rx, cy, rx + right_w, cy + ch, 6, 6, 6, 6, 6)
    draw.Color(unpack(ui.clr.outline))
    draw.RoundedRect(rx, cy, rx + right_w, cy + ch, 6, 6, 6, 6, 6)

    draw.SetFont(f_group)
    draw.Color(255, 255, 255, 255)
    draw.Text(lx + 14, cy - 7, "MAP DATABASE")
    draw.Text(rx + 14, cy - 7, "WALLBANG LOCATIONS")

    local maps = osnova_wb_maps()
