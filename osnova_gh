local function mouse_in(x, y, w, h)
    local mx, my = input.GetMousePos()
    return mx >= x and mx <= x + w and my >= y and my <= y + h
end

local function lerp(a, b, t) return a + (b - a) * t end

-- Angle (deg) within which we consider the crosshair "on" the aim point.
-- Kept tight so the throw / macro only fires when the crosshair is
-- essentially dead-centre on the aim point (no noticeable offset).
local AIM_LOCK_ANGLE_DEG = 0.6

-- Aim / selection FOV, measured in SCREEN PIXELS as a radius around the
-- crosshair (screen centre). A saved location only becomes a candidate to
-- auto-aim / auto-walk / play back when its AIM POINT projects within this
-- many pixels of the crosshair. Among candidates the one closest to the
-- crosshair wins. This replaces the old "nearest ground spot / most recently
-- created" selection logic.
local AIM_FOV_PX = 160

local function osnova_angle_diff(a, b)
    local d = b - a
    while d > 180 do d = d - 360 end
    while d < -180 do d = d + 360 end
    return d
end

local function osnova_is_aimed_at(origin, target_vec)
    local view = nil
    pcall(function() view = engine.GetViewAngles() end)
    if not view then
        local lp = entities.GetLocalPlayer()
        if lp then pcall(function() view = lp:GetAbsAngles() end) end
    end
    if not view then return false end

    local eye = Vector3(origin.x, origin.y, origin.z + 64)
    local dir = target_vec - eye
    local target_angles = dir:Angles()

    local cur_pitch = view.pitch or view.x or 0
    local cur_yaw = view.yaw or view.y or 0
    local tgt_pitch = target_angles.pitch or target_angles.x or 0
    local tgt_yaw = target_angles.yaw or target_angles.y or 0

    local dpitch = osnova_angle_diff(cur_pitch, tgt_pitch)
    local dyaw = osnova_angle_diff(cur_yaw, tgt_yaw)
    local angle_dist = math.sqrt(dpitch * dpitch + dyaw * dyaw)

    return angle_dist <= AIM_LOCK_ANGLE_DEG, angle_dist
end

