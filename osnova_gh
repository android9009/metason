local function osnova_location_has_position(loc)
    return type(loc) == "table"
        and type(loc.pos_x) == "number"
        and type(loc.pos_y) == "number"
        and type(loc.pos_z) == "number"
end

local function osnova_compact_locations(locs, context)
    local compact, removed = {}, 0
    for _, loc in pairs(locs or {}) do
        if osnova_location_has_position(loc) then
            table.insert(compact, loc)
        else
            removed = removed + 1
            osnova_debug("removed invalid saved location" .. (context and (" (" .. context .. ")") or "") .. ": " .. tostring(loc and loc.name or "nil"))
        end
    end
    return compact, removed
end

local function osnova_sanitize_database()
    for map, md in pairs(ui.map_data or {}) do
        if type(md) == "table" then
            if md.groups then
                for def, grp in pairs(md.groups) do
                    if type(grp) == "table" then
                        grp.locations = osnova_compact_locations(grp.locations, tostring(map) .. "/group " .. tostring(def))
                    end
                end
            end
            if md.movement_helpers then
                for id, mh in pairs(md.movement_helpers) do
                    if type(mh) == "table" then
                        mh.locations = osnova_compact_locations(mh.locations, tostring(map) .. "/movement " .. tostring(id))
                    end
                end
            end
            -- Wallbang locations can be partially edited (only FROM point saved),
            -- so do not delete them with regular pos_x sanitizer.
            if md.wallbang then md.wallbang.locations = md.wallbang.locations or {} end
        end
    end
end

local function osnova_merge_loaded_maps()
    local merged = {}
    for map, md in pairs(ui.map_data or {}) do
        local norm = osnova_normalize_map_name(map)
        merged[norm] = merged[norm] or osnova_empty_map_data()
        local dst = merged[norm]
        if type(md) == "table" then
            if md.groups then
                for def, grp in pairs(md.groups) do
                    local cdef = osnova_canon_def_early(def)
                    dst.groups[cdef] = dst.groups[cdef] or { locations = {} }
                    for _, loc in pairs((grp or {}).locations or {}) do
                        table.insert(dst.groups[cdef].locations, loc)
                    end
                end
            end
            if md.movement_helpers then
                for id, mh in pairs(md.movement_helpers) do
                    dst.movement_helpers[id] = dst.movement_helpers[id] or { locations = {} }
                    for _, loc in pairs((mh or {}).locations or {}) do
                        table.insert(dst.movement_helpers[id].locations, loc)
                    end
                end
            end
            if md.wallbang then
                dst.wallbang = dst.wallbang or { locations = {} }
                for _, loc in pairs((md.wallbang or {}).locations or {}) do
                    table.insert(dst.wallbang.locations, loc)
                end
            end
        end
    end
    ui.map_data = merged
end

local function osnova_save_database()
    osnova_sanitize_database()
    pcall(function() file.Write(ui.data_file, "return " .. osnova_serialize_value(ui.map_data)) end)
end

local function osnova_load_database()
    local ok, data = pcall(function() return file.Read(ui.data_file) end)
    if not ok then
        osnova_debug("file.Read failed for " .. tostring(ui.data_file) .. ": " .. tostring(data))
    elseif not data or data == "" then
        osnova_debug("database file empty/missing: " .. tostring(ui.data_file))
    else
        osnova_debug("read " .. tostring(string.len(data)) .. " bytes from " .. tostring(ui.data_file))
        local loader = loadstring or load
        local ok_load, loaded = pcall(function()
            local fn, compile_err = loader(data)
            if not fn then return nil, compile_err end
            return fn()
        end)
        if ok_load and type(loaded) == "table" then
            ui.map_data = loaded
            osnova_debug("database lua parse OK")
        else
            osnova_debug("database lua parse FAILED: " .. tostring(loaded))
        end
    end
    osnova_merge_loaded_maps()
    osnova_sanitize_database()
    osnova_update_current_map()
    local md = osnova_ensure_map_data(ui.current_map)
    for def, grp in pairs(ui.groups) do
        local cdef = osnova_canon_def_early(def)
        if grp.locations and #grp.locations > 0 and osnova_count_locations(md.groups[cdef].locations) == 0 then md.groups[cdef].locations = grp.locations end
    end
    for id, mh in pairs(ui.movement_helpers) do
        if mh.locations and #mh.locations > 0 and osnova_count_locations(md.movement_helpers[id].locations) == 0 then md.movement_helpers[id].locations = mh.locations end
    end
    osnova_debug_database_summary("loaded")
    osnova_save_database()
end

osnova_load_database()

-- ==================== GITHUB CLOUD LOCATIONS ====================
-- Cloud packs are pulled from GitHub directly from repo /lua folder.
-- Upload/create/delete is intentionally not handled here; this only Refresh + Load.
local function osnova_cloud_api_url(path)
    path = path or ui.cloud.root
    return "https://api.github.com/repos/" .. ui.cloud.owner .. "/" .. ui.cloud.repo .. "/contents/" .. path .. "?ref=" .. ui.cloud.branch
end

local function osnova_cloud_raw_url(path)
    return "https://raw.githubusercontent.com/" .. ui.cloud.owner .. "/" .. ui.cloud.repo .. "/" .. ui.cloud.branch .. "/" .. path
end

local function osnova_cloud_fetch(url)
    local ok, body = pcall(function() return http.Get(url) end)
    if ok and body and body ~= "" then return body end
    return nil
end

local function osnova_cloud_parse_contents(json)
    local items = {}
    if not json or json == "" then return items end
    for obj in string.gmatch(json, "{%s*.-%s*}") do
        local name = obj:match('"name"%s*:%s*"([^"]+)"')
        local path = obj:match('"path"%s*:%s*"([^"]+)"')
        local typ = obj:match('"type"%s*:%s*"([^"]+)"')
        local download = obj:match('"download_url"%s*:%s*"([^"]-)"')
        if name and path and typ then
            table.insert(items, { name = name, path = path, type = typ, download_url = download })
        end
    end
    table.sort(items, function(a, b) return tostring(a.name) < tostring(b.name) end)
    return items
end

local function osnova_cloud_file_allowed(name)
    name = tostring(name or "")
    if name:match("%.txt$") then return true end
    if name:match("%.lua$") then return true end
    -- also allow extensionless packs like current /lua/gh
    if not name:match("%.[^%.]+$") then return true end
    return false
end

local function osnova_cloud_sync_files()
    ui.cloud.files = {}
    ui.cloud.selected_file = 1

    local body = osnova_cloud_fetch(osnova_cloud_api_url(ui.cloud.root))
    local items = osnova_cloud_parse_contents(body)
    for _, it in ipairs(items) do
        if it.type == "file" and osnova_cloud_file_allowed(it.name) then
            table.insert(ui.cloud.files, it)
        end
    end

    ui.cloud.synced = true
    ui.cloud.enabled = (#ui.cloud.files > 0) and true or ui.cloud.enabled
    ui.cloud.status = "github files: " .. tostring(#ui.cloud.files)
end

-- Backwards name kept for older calls.
local function osnova_cloud_sync_people()
    osnova_cloud_sync_files()
end

local function osnova_cloud_load_file_data(file_item)
    if not file_item then return nil end
    local url = file_item.download_url
    if not url or url == "null" or url == "" then url = osnova_cloud_raw_url(file_item.path) end
    local body = osnova_cloud_fetch(url)
    if not body then return nil end
    local loader = loadstring or load
    local ok_load, data = pcall(function()
        local fn = loader(body)
        return fn and fn()
    end)
    if ok_load and type(data) == "table" then return data end
    return nil
end

local function osnova_cloud_location_exists(list, loc)
    if not loc then return false end
    for _, existing in pairs(list or {}) do
        if existing and existing.name == loc.name
            and math.abs((existing.pos_x or 0) - (loc.pos_x or 0)) < 0.01
            and math.abs((existing.pos_y or 0) - (loc.pos_y or 0)) < 0.01
            and math.abs((existing.pos_z or 0) - (loc.pos_z or 0)) < 0.01 then
            return true
        end
    end
    return false
end

local function osnova_cloud_append_location(dst, loc, source)
    if not osnova_location_has_position(loc) then return 0 end
    if osnova_cloud_location_exists(dst, loc) then return 0 end
    loc.cloud_author = source
    loc.cloud_source = source
    table.insert(dst, loc)
    return 1
end

local function osnova_cloud_import_data(data, source)
    if type(data) ~= "table" then return 0 end
    local imported = 0
    local target_current_only = ui.cloud.current_map_only
    osnova_update_current_map()

    for map, md in pairs(data) do
        if type(md) == "table" then
            local target_map = target_current_only and ui.current_map or osnova_normalize_map_name(map)
            local dst_md = osnova_ensure_map_data(target_map)

            if md.groups then
                for def, grp in pairs(md.groups) do
                    local cdef = osnova_canon_def_early(def)
                    dst_md.groups[cdef] = dst_md.groups[cdef] or { locations = {} }
                    for _, loc in pairs((grp or {}).locations or {}) do
                        imported = imported + osnova_cloud_append_location(dst_md.groups[cdef].locations, loc, source)
                    end
                end
            end

            if md.movement_helpers then
                for id, mh in pairs(md.movement_helpers) do
                    dst_md.movement_helpers[id] = dst_md.movement_helpers[id] or { locations = {} }
                    for _, loc in pairs((mh or {}).locations or {}) do
                        imported = imported + osnova_cloud_append_location(dst_md.movement_helpers[id].locations, loc, source)
                    end
                end
            end
        end
    end

    if imported > 0 then osnova_save_database(); sync_current_locations() end
    return imported
end

local function osnova_cloud_import_selected()
    local file_item = ui.cloud.files[ui.cloud.selected_file]
    if not file_item then ui.cloud.status = "select file"; return end
    local data = osnova_cloud_load_file_data(file_item)
    if not data then ui.cloud.status = "bad github file"; return end
