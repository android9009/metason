local function draw_listbox(x, y, w, h, items, mode)
    draw.Color(13, 13, 13, 255)
    draw.FilledRect(x, y, x + w, y + h)
    draw.Color(unpack(ui.clr.outline))
    draw.OutlinedRect(x, y, x + w, y + h)
    if not items or #items == 0 then return end

    local sc = "location_scroll"
    if mode == "group" then
        sc = "group_scroll"
    elseif mode == "movement" then
        sc = "movement_scroll"
    end
    if mouse_in(x, y, w, h) then ui[sc] = math.max(0, ui[sc] - input.GetMouseWheelDelta()) end

    for i = ui[sc] + 1, #items do
        local display_idx = i - ui[sc]
        local iy = y + (display_idx - 1) * 22
        if iy + 22 > y + h then break end

        local hover = mouse_in(x, iy, w, 22)
        local selected = false

        if mode == "group" then
            selected = (ui.selected_browser == "group" and ui.selected_group == items[i].def)
        elseif mode == "movement" then
            selected = (ui.selected_browser == "movement" and ui.selected_movement_helper == items[i].id)
        elseif mode == "location" then
            selected = (ui.selected_location == i)
        end

        if selected then
            draw.Color(255, 255, 255, 40)
            draw.FilledRect(x + 1, iy + 1, x + w - 1, iy + 21)
            draw.Color(255, 255, 255, 220)
            draw.FilledRect(x + 1, iy + 1, x + 3, iy + 21)
        elseif hover and mode ~= "none" then
            draw.Color(255, 255, 255, 8)
            draw.FilledRect(x + 1, iy + 1, x + w - 1, iy + 21)
        end

        draw.SetFont(f_main)
        local name = items[i].name or tostring(items[i])
        if selected and ui.renaming and ui.rename_target == mode then name = ui.rename_buf .. "_" end

        local text_x = x + 10
        local tex = nil
        
        -- Get icon texture based on mode and items[i]
        if mode == "group" and items[i].def then
            local icon_id = items[i].def
            if _G.GH_ICONS.cache[icon_id] then
                tex = _G.GH_ICONS.cache[icon_id]
            end
        elseif mode == "location" then
            if ui.selected_browser == "group" and ui.selected_group then
                local icon_id = ui.selected_group
                if _G.GH_ICONS.cache[icon_id] then
                    tex = _G.GH_ICONS.cache[icon_id]
                end
            end
        end

        if tex then
            local max_icon_h = 14
            local scale = math.min(1.0, max_icon_h / tex.height)
            local tex_w = math.floor(tex.width * scale)
            local tex_h = math.floor(tex.height * scale)
            
            draw.Color(selected and 255 or 160, selected and 255 or 160, selected and 255 or 160, 255)
            draw.SetTexture(tex.texture)
            local tex_y = iy + math.floor((22 - tex_h) / 2)
            draw.FilledRect(text_x, tex_y, text_x + tex_w, tex_y + tex_h)
            draw.SetTexture(nil)
            text_x = text_x + tex_w + 5
        end

        draw.Color(selected and 255 or 160, selected and 255 or 160, selected and 255 or 160, 255)
        draw.Text(text_x, iy + 4, name)


        if hover and input.IsButtonPressed(1) and not ui.active_combo and not ui._combo_blocked then
            if mode == "group" then
                ui.selected_browser = "group"
                ui.selected_group = items[i].def
                ui.selected_location = 0
                ui.renaming = false
                sync_current_locations()
            elseif mode == "movement" then
                ui.selected_browser = "movement"
                ui.selected_movement_helper = items[i].id
                ui.selected_location = 0
                ui.edit_mode = false
                ui.renaming = false
                sync_current_locations()
            elseif mode == "location" then
                ui.selected_location = i
                ui.renaming = false
            end
        end
    end
end

