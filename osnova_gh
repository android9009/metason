local function osnova_get_speed2d(local_player)
    local speed2d = 0
    pcall(function()
        local vel = local_player:GetPropVector("m_vecVelocity") or local_player:GetPropVector("localdata", "m_vecVelocity")
        if vel then
            speed2d = vel.Length2D and vel:Length2D() or math.sqrt((vel.x or 0) ^ 2 + (vel.y or 0) ^ 2)
        end
    end)
    return speed2d
end

