local function draw_bind(x, y, w, label, target_type, current_key)
    local bw = 86
    local bh = 22
    local bx = x + w - bw
    local by = y - 3
    local hover = mouse_in(bx, by, bw, bh)
    local listening = ui.binding and ui.bind_target == target_type
    local right_hint = (target_type == "main_enable")

    -- label
    draw.SetFont(f_main)
    draw.Color(listening and 255 or 220, listening and 255 or 220, listening and 255 or 220, 255)
    draw.Text(x, y, label)

    -- key name
    local name = listening and "PRESS KEY" or (keys[current_key] or "[" .. tostring(current_key) .. "]")
    if target_type == "main_enable" and ui.settings.mode == 0 and not listening then name = "ALWAYS" end

    -- soft background shadow
    draw.Color(0, 0, 0, hover and 105 or 65)
    draw.ShadowRect(bx, by, bx + bw, by + bh, hover and 12 or 8)

    -- body
    local bg = listening and 235 or (hover and 38 or 20)
    local fg = listening and 14 or (hover and 245 or 185)
    local br = listening and 255 or (hover and 86 or 46)

    draw.Color(bg, bg, bg, 255)
    draw.RoundedRectFill(bx, by, bx + bw, by + bh, 6, 6, 6, 6, 6)
    draw.Color(br, br, br, 255)
    draw.RoundedRect(bx, by, bx + bw, by + bh, 6, 6, 6, 6, 6)

    -- small left status capsule
    draw.Color(listening and 20 or 255, listening and 20 or 255, listening and 20 or 255, listening and 255 or (hover and 205 or 125))
    draw.RoundedRectFill(bx + 4, by + 5, bx + 7, by + bh - 5, 2, 2, 0, 2, 0)

    -- key text
    draw.SetFont(f_bind)
    draw.Color(fg, fg, fg, 255)
    local tw, th = draw.GetTextSize(name)
    draw.Text(bx + (bw - tw) / 2 + 2, by + (bh - th) / 2, name)

    -- tiny mode dots for Enable Helper: right click opens mode selector
    if right_hint and not listening then
        local mode = ui.settings.mode or 1
        for i = 0, 2 do
            local dx = bx + bw - 18 + i * 5
            local dy = by + bh - 5
            if mode == i then
                draw.Color(255, 255, 255, hover and 230 or 170)
                draw.FilledCircle(dx, dy, 2)
            else
                draw.Color(95, 95, 95, 180)
                draw.FilledCircle(dx, dy, 1)
            end
        end
    end

    if hover and input.IsButtonPressed(1) and not ui.binding and not ui.bind_click_block and not ui.active_combo and not ui._combo_blocked then
        ui.binding = true
        ui.bind_target = target_type
        ui._combo_blocked = true
    end

    if hover and input.IsButtonPressed(2) and not ui.binding and not ui.bind_click_block and target_type == "main_enable" and not ui.active_combo and not ui._combo_blocked then
        ui.popup.open = true
        ui.popup.x, ui.popup.y = input.GetMousePos()
        ui._combo_blocked = true
    end
end

local function process_combo_input()
    ui._combo_blocked = false
    if not ui.active_combo then return end
    if not input.IsButtonPressed(1) then return end

    local c = ui.active_combo
    local max_h = 110
    local h = math.min(#c.items * 22, max_h)

    for i = c.scroll + 1, #c.items do
        local d_idx = i - c.scroll
        local iy = c.y + (d_idx - 1) * 22
        if iy + 22 > c.y + h + 1 then break end
        if mouse_in(c.x, iy, c.w, 22) then
            c.target[c.var] = i
            ui.active_combo = nil
            ui._combo_blocked = true
            return
        end
    end

    if not mouse_in(c.x, c.y - 22, c.w, h + 22) then
        ui.active_combo = nil
        ui._combo_blocked = true
    end
end

local function render_active_combo()
    if not ui.active_combo then return end

    local c = ui.active_combo
    local max_h = 110
    local h = math.min(#c.items * 22, max_h)

    if mouse_in(c.x, c.y, c.w, h) then
        c.scroll = math.max(0, math.min(#c.items - 5, c.scroll - input.GetMouseWheelDelta()))
    end

    draw.Color(15, 15, 15, 255)
    draw.FilledRect(c.x, c.y, c.x + c.w, c.y + h)
    draw.Color(unpack(ui.clr.outline))
    draw.OutlinedRect(c.x, c.y, c.x + c.w, c.y + h)

    for i = c.scroll + 1, #c.items do
        local d_idx = i - c.scroll
        local iy = c.y + (d_idx - 1) * 22
        if iy + 22 > c.y + h + 1 then break end

        local hov = mouse_in(c.x, iy, c.w, 22)
        local sel = (c.target[c.var] == i)

        if sel then
            draw.Color(255, 255, 255, 30)
            draw.FilledRect(c.x + 1, iy + 1, c.x + c.w - 1, iy + 21)
        elseif hov then
            draw.Color(255, 255, 255, 10)
            draw.FilledRect(c.x + 1, iy + 1, c.x + c.w - 1, iy + 21)
        end

        draw.SetFont(f_bind)
        draw.Color(sel and 255 or 150, sel and 255 or 150, sel and 255 or 150, 255)
        draw.Text(c.x + 10, iy + 4, c.items[i])
    end
end

