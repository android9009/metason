    REC.active = true
    REC.loc = loc
    REC.start_time = common.Time()
    REC.events = {}
    REC.down_state = {}
    REC.stop_at = nil
    REC.last_cam_sample = nil
    REC.last_pitch = nil
    REC.last_yaw = nil
    for _, k in ipairs(RECORD_VK_LIST) do
        REC.down_state[k.id] = false
    end
    osnova_record_camera(common.Time(), 0)
end

osnova_record_camera = function(now, t_ms)
    if REC.last_cam_sample and (now - REC.last_cam_sample) < CAMERA_SAMPLE_INTERVAL then
        return
    end
    REC.last_cam_sample = now

    local view = nil
    pcall(function() view = engine.GetViewAngles() end)
    if not view then return end

    local pitch = view.pitch or view.x or 0
    local yaw = view.yaw or view.y or 0

    if REC.last_pitch == nil or math.abs(osnova_angle_diff(REC.last_pitch, pitch)) > 0.01
        or math.abs(osnova_angle_diff(REC.last_yaw, yaw)) > 0.01 then
        REC.last_pitch = pitch
        REC.last_yaw = yaw
        table.insert(REC.events, { t = t_ms, key = "look", pitch = pitch, yaw = yaw })
    end
end

