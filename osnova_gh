-- ==================== MAP-SPECIFIC LOCATION STORAGE ====================
local function osnova_canon_def_early(def)
    if def == 48 then return 46 end
    return def
end

local function osnova_normalize_map_name(map)
    map = tostring(map or "unknown")
    map = map:gsub("\\", "/")
    map = map:match("([^/]+)$") or map
    map = map:gsub("%.bsp$", "")
    map = map:gsub("%.vpk$", "")
    return map
end

local function osnova_get_map_name()
    local map = nil
    local tries = {
        function() return engine and engine.GetMapName and engine.GetMapName() end,
        function() return engine and engine.GetLevelName and engine.GetLevelName() end,
        function() return client and client.GetMapName and client.GetMapName() end,
        function() return globals and globals.MapName and globals.MapName() end,
    }
    for _, fn in ipairs(tries) do
        local ok, v = pcall(fn)
        if ok and v and tostring(v) ~= "" then map = tostring(v); break end
    end
    return osnova_normalize_map_name(map or "unknown")
end

local function osnova_empty_map_data()
    return {
        groups = {
            [45] = { locations = {} }, [44] = { locations = {} },
            [46] = { locations = {} }, [43] = { locations = {} },
            [47] = { locations = {} },
        },
        movement_helpers = { [1] = { locations = {} } },
        wallbang = { locations = {} }
    }
end

local function osnova_ensure_map_data(map)
    map = map or osnova_get_map_name()
    ui.map_data[map] = ui.map_data[map] or osnova_empty_map_data()
    local md = ui.map_data[map]
    md.groups = md.groups or {}
    md.movement_helpers = md.movement_helpers or {}
    md.wallbang = md.wallbang or { locations = {} }
    md.wallbang.locations = md.wallbang.locations or {}
    for def, _ in pairs(ui.groups) do
        local cdef = osnova_canon_def_early(def)
        md.groups[cdef] = md.groups[cdef] or { locations = {} }
        md.groups[cdef].locations = md.groups[cdef].locations or {}
    end
    for id, _ in pairs(ui.movement_helpers) do
        md.movement_helpers[id] = md.movement_helpers[id] or { locations = {} }
        md.movement_helpers[id].locations = md.movement_helpers[id].locations or {}
    end
    return md
end

local function osnova_update_current_map()
    local map = osnova_get_map_name()
    if ui.current_map ~= map then
        ui.current_map = map
        ui.selected_location = 0
        ui.location_scroll = 0
    end
    osnova_ensure_map_data(map)
    return map
end

local function osnova_get_locations_for(map, browser, id)
    local md = osnova_ensure_map_data(map)
    if browser == "movement" then
        local mh = md.movement_helpers[id or ui.selected_movement_helper]
        return (mh and mh.locations) or {}
    end
    local def = osnova_canon_def_early(id or ui.selected_group)
    local grp = md.groups[def]
    return (grp and grp.locations) or {}
end

local function osnova_count_locations(locs)
    local n = 0
    for _, loc in pairs(locs or {}) do
        if type(loc) == "table" then n = n + 1 end
    end
    return n
end

