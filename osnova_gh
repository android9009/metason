local function osnova_load_config()
    local ok, data = pcall(function() return file.Read(ui.config_file) end)
    if not ok or not data or data == "" then return end

    local loader = loadstring or load
    local ok_load, cfg = pcall(function()
        local fn = loader(data)
        return fn and fn()
    end)

    if ok_load and type(cfg) == "table" and type(cfg.settings) == "table" then
        local st = cfg.settings
        ui.settings.key = tonumber(st.key) or ui.settings.key or 0
        ui.settings.mode = tonumber(st.mode) or ui.settings.mode or 1
        ui.settings.save_key = tonumber(st.save_key) or ui.settings.save_key or 0
        ui.settings.auto_key = tonumber(st.auto_key) or ui.settings.auto_key or 0
        ui.settings.delete_key = tonumber(st.delete_key) or ui.settings.delete_key or 0
        ui.settings.smooth = tonumber(st.smooth) or ui.settings.smooth or 50
        ui.settings.reaction = tonumber(st.reaction) or ui.settings.reaction or 100
        ui.settings.fov = tonumber(st.fov) or ui.settings.fov or 160
    end
end

