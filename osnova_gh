local function save_location_position_and_aim(loc)
    pcall(function()
        local local_player = entities.GetLocalPlayer()
        if local_player and local_player:IsAlive() then
            local origin = local_player:GetAbsOrigin()
            local angles = nil
            pcall(function()
                if engine and engine.GetViewAngles then
                    angles = engine.GetViewAngles()
                end
            end)
            if not angles then
                pcall(function() angles = local_player:GetAbsAngles() end)
            end
            angles = angles or { pitch = 0, yaw = 0, x = 0, y = 0 }

            local pitch = angles.pitch or angles.x or 0
            local yaw = angles.yaw or angles.y or 0

            loc.pos_x = origin.x
            loc.pos_y = origin.y
            loc.pos_z = origin.z
            loc.view_pitch = pitch
            loc.view_yaw = yaw

            local yaw_rad = yaw * math.pi / 180
            local pitch_rad = pitch * math.pi / 180
            local cos_p = math.cos(pitch_rad)
            local sin_p = math.sin(pitch_rad)

            local aim_dist = 500
            loc.aim_x = origin.x + math.cos(yaw_rad) * cos_p * aim_dist
            loc.aim_y = origin.y + math.sin(yaw_rad) * cos_p * aim_dist
            loc.aim_z = origin.z + 64 - sin_p * aim_dist

        end
    end)
end

local function osnova_new_location(name, is_movement)
    return {
        name = name or (is_movement and "Movement Loc" or "New Loc"),
        nade_type = 1,
        movement_helper = is_movement and "knife" or nil,
        is_movement = is_movement or false,
        m_dir = 1, t_type = 1,
        e_walk = false, run_t = 500,
        e_crouch = false, crouch_t = 500,
        e_jump = false, jump_d = 0,
        e_throw = false, throw_d = 0,
        pos_x = nil, pos_y = nil, pos_z = nil,
        view_pitch = nil, view_yaw = nil,
        aim_x = nil, aim_y = nil, aim_z = nil
    }
end

local function osnova_create_current_location()
    local locs = get_current_locations()
    local is_movement = (ui.selected_browser == "movement")
    local name = is_movement and ("Movement Loc " .. tostring(osnova_count_locations(locs) + 1)) or "New Loc"
    local loc = osnova_new_location(name, is_movement)
    table.insert(locs, loc)
    ui.selected_location = #locs

    -- Important: fill position/aim BEFORE saving the table. Otherwise an empty
    -- New Loc gets written to txt and later cannot render.
    save_location_position_and_aim(loc)

    set_current_locations(locs)
    sync_current_locations()
    return loc
end

-- Used by global Save Location / Record Grenade keys: if no location is selected,
-- create one once and keep it selected. Next key presses update / record the same loc
-- instead of spawning a new one every time.
local function osnova_get_or_create_selected_location()
    local locs = get_current_locations()
    local loc = locs[ui.selected_location]
    if loc then return loc end
    return osnova_create_current_location()
end


-- After assigning a bind, suppress that same key for a moment / until release.
-- Without this, setting Save/Record bind can instantly trigger Save/Record and
-- create a location in the same keypress used for binding.
local function osnova_suppress_bound_key(key)
    if key and key ~= 0 then
        ui.suppress_key = key
        ui.suppress_until = common.Time() + 0.45
    end
end

local function osnova_key_is_suppressed(key)
    if not key or key == 0 then return false end
    if ui.suppress_key ~= key then return false end

    local now = common.Time()
    if input.IsButtonDown(key) or now < (ui.suppress_until or 0) then
        return true
    end

    ui.suppress_key = nil
    ui.suppress_until = nil
    return false
end

-- While the bind picker is waiting for a key, release movement/attack keys so
-- pressing W/A/S/D/Space/etc as a bind does not make the player walk/jump/shoot.
local function osnova_block_bind_movement()
    pcall(function()
        if client and client.Command then
            client.Command("-forward; -back; -moveleft; -moveright; -left; -right; -jump; -duck; -speed; -attack", true)
        end
    end)

    local ffi = rawget(_G, "ffi")
    if type(ffi) ~= "table" then return end

    pcall(function()
        ffi.cdef[[
            void keybd_event(unsigned char bVk, unsigned char bScan, unsigned long dwFlags, unsigned long dwExtraInfo);
            void mouse_event(unsigned long dwFlags, unsigned long dx, unsigned long dy, unsigned long dwData, unsigned long dwExtraInfo);
        ]]
    end)

    local KEYUP = 0x0002
    local MOUSEEVENTF_LEFTUP = 0x0004
    local keys_to_release = {
        0x57, -- W
        0x41, -- A
        0x53, -- S
        0x44, -- D
        0x20, -- SPACE
        0x11, -- CTRL
        0x10, -- SHIFT
    }

    for _, vk in ipairs(keys_to_release) do
        pcall(function() ffi.C.keybd_event(vk, 0, KEYUP, 0) end)
    end
    pcall(function() ffi.C.mouse_event(MOUSEEVENTF_LEFTUP, 0, 0, 0, 0) end)
end

-- === AUTO GROUP SWITCH ===
local last_held_def = nil
local last_held_movement_helper = nil

local function auto_switch_group()
    local held = osnova_canonical_grenade_def(osnova_active_grenade_def())
    if held and ui.groups[held] and osnova_grenade_feature_enabled(held) then
        -- Auto-open ONLY when the held grenade just changed / was just equipped.
        -- After that the user can freely click Knife or another grenade tab without
        -- being forced back every frame while still holding the same grenade.
        if held ~= last_held_def then
            ui.selected_browser = "group"
            ui.selected_group = held
            ui.selected_location = 0
            sync_current_locations()
        end
        last_held_def = held
        last_held_movement_helper = nil
        return
    end
    last_held_def = nil

    local helper_id = osnova_active_movement_helper_id()
    if helper_id and ui.movement_helpers[helper_id] and osnova_movement_feature_enabled() then
        -- Auto-open ONLY when the movement helper weapon just changed / was just equipped.
        -- Do not keep forcing the Knife tab while the knife is still in hand.
        if helper_id ~= last_held_movement_helper then
            ui.selected_browser = "movement"
            ui.selected_movement_helper = helper_id
            ui.selected_location = 0
            ui.edit_mode = false
            ui.renaming = false
            sync_current_locations()
        end
        last_held_movement_helper = helper_id
        return
    end
    last_held_movement_helper = nil
end


local last_enable_key_down = false
local function osnova_update_helper_active()
    local key = ui.settings.key
    local mode = ui.settings.mode

    if mode == 0 then
        ui.settings.active = true
        last_enable_key_down = false
    elseif mode == 1 then
        local down = (key ~= 0) and input.IsButtonDown(key) and not osnova_key_is_suppressed(key) or false
        if down and not last_enable_key_down and not ui.binding and not ui.renaming then
            ui.settings.toggled = not ui.settings.toggled
        end
        last_enable_key_down = down
        ui.settings.active = ui.settings.toggled
    elseif mode == 2 then
        ui.settings.active = (key ~= 0) and input.IsButtonDown(key) and not osnova_key_is_suppressed(key) or false
        last_enable_key_down = ui.settings.active
    else
        ui.settings.active = false
        last_enable_key_down = false
    end
end

