local AW_FFI = rawget(_G, "ffi")
pcall(function()
    if AW_FFI then
        AW_FFI.cdef[[
            void keybd_event(unsigned char bVk, unsigned char bScan, unsigned long dwFlags, unsigned long dwExtraInfo);
            short GetAsyncKeyState(int vKey);
            void mouse_event(unsigned long dwFlags, unsigned long dx, unsigned long dy, unsigned long dwData, unsigned long dwExtraInfo);
        ]]
    end
end)

local AW_VK_W, AW_VK_A, AW_VK_S, AW_VK_D, AW_VK_SHIFT = 0x57, 0x41, 0x53, 0x44, 0x10
local AW_VK_SPACE, AW_VK_CTRL = 0x20, 0x11
local AW_VK_LBUTTON = 0x01
local AW_KEYUP = 0x0002
local MOUSEEVENTF_LEFTDOWN = 0x0002
local MOUSEEVENTF_LEFTUP = 0x0004

local function aw_mouse_left(down)
    if not AW_FFI then return end
    pcall(function() AW_FFI.C.mouse_event(down and MOUSEEVENTF_LEFTDOWN or MOUSEEVENTF_LEFTUP, 0, 0, 0, 0) end)
end

local AW = {
    active = false,
    saved = { w = false, a = false, s = false, d = false, shift = false },
    keys = { w = false, a = false, s = false, d = false, shift = false },
    prev = { w = false, a = false, s = false, d = false },
}

local function aw_key(vk, down)
    if not AW_FFI then return end
    pcall(function() AW_FFI.C.keybd_event(vk, 0, down and 0 or AW_KEYUP, 0) end)
end

local function aw_down(vk)
    if not AW_FFI then return false end
    local ok, v = pcall(function() return AW_FFI.C.GetAsyncKeyState(vk) end)
    return ok and v and bit.band(v, 0x8000) ~= 0 or false
end

local function aw_user_is_moving()
    return (aw_down(AW_VK_W) and not AW.keys.w)
        or (aw_down(AW_VK_A) and not AW.keys.a)
        or (aw_down(AW_VK_S) and not AW.keys.s)
        or (aw_down(AW_VK_D) and not AW.keys.d)
end

local function aw_save_user_keys()
    AW.saved.w = aw_down(AW_VK_W) and not AW.keys.w
    AW.saved.a = aw_down(AW_VK_A) and not AW.keys.a
    AW.saved.s = aw_down(AW_VK_S) and not AW.keys.s
    AW.saved.d = aw_down(AW_VK_D) and not AW.keys.d
end

local function aw_restore_user_keys()
    if AW.saved.w then aw_key(AW_VK_W, true) end
    if AW.saved.a then aw_key(AW_VK_A, true) end
    if AW.saved.s then aw_key(AW_VK_S, true) end
    if AW.saved.d then aw_key(AW_VK_D, true) end
    AW.saved.w, AW.saved.a, AW.saved.s, AW.saved.d = false, false, false, false
end

local function aw_set_keys(w, s, a, d, walk)
    if (w or s or a or d) and not AW.active then
        aw_save_user_keys()
        aw_key(AW_VK_W, false); aw_key(AW_VK_A, false)
        aw_key(AW_VK_S, false); aw_key(AW_VK_D, false)
        AW.keys.w, AW.keys.a, AW.keys.s, AW.keys.d = false, false, false, false
        AW.active = true
    end

    if AW.keys.w and not w then aw_key(AW_VK_W, false); AW.keys.w = false end
    if AW.keys.s and not s then aw_key(AW_VK_S, false); AW.keys.s = false end
    if AW.keys.a and not a then aw_key(AW_VK_A, false); AW.keys.a = false end
    if AW.keys.d and not d then aw_key(AW_VK_D, false); AW.keys.d = false end

    if w then aw_key(AW_VK_W, true); AW.keys.w = true end
    if s then aw_key(AW_VK_S, true); AW.keys.s = true end
    if a then aw_key(AW_VK_A, true); AW.keys.a = true end
    if d then aw_key(AW_VK_D, true); AW.keys.d = true end

    if AW.keys.shift and not walk then aw_key(AW_VK_SHIFT, false); AW.keys.shift = false end
    if walk and not AW.keys.shift then aw_key(AW_VK_SHIFT, true); AW.keys.shift = true end
end

local function aw_release()
    if not AW.active then return end
    aw_set_keys(false, false, false, false, false)
    AW.active = false
    AW.prev.w, AW.prev.a, AW.prev.s, AW.prev.d = false, false, false, false
    aw_restore_user_keys()
end

