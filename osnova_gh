-- AIM
local AIM = { current_target = nil, start_time = 0 }

local function lerp_angle(a, b, t)
    local d = b - a
    while d > 180 do d = d - 360 end
    while d < -180 do d = d + 360 end
    return a + d * t
end

local function osnova_aim_at_point()
    osnova_update_helper_active()
    if not ui.settings.active then AIM.current_target = nil; return end
    local action_locs = osnova_get_action_locations()
    if not action_locs or #action_locs == 0 then AIM.current_target = nil; return end
    -- during a macro replay the camera is driven by the recorded samples;
    -- keep the auto-aim from nudging it off the exact recorded angles
    if osnova_any_macro_playing() then AIM.current_target = nil; return end

    local local_player = entities.GetLocalPlayer()
    if not local_player or not local_player:IsAlive() then AIM.current_target = nil; return end

    local origin = local_player:GetAbsOrigin()
    local target_loc = osnova_find_target_location(origin)

    if not target_loc or not (target_loc.aim_x and target_loc.aim_y and target_loc.aim_z) then
        AIM.current_target = nil
        return
    end

    if target_loc.macro and target_loc.seq_active then
        AIM.current_target = nil
        return
    end

    local arrive_dist = math.sqrt((origin.x - target_loc.pos_x) ^ 2 + (origin.y - target_loc.pos_y) ^ 2)
    local speed2d = osnova_get_speed2d(local_player)
    if arrive_dist > ARRIVED_DIST or speed2d >= ARRIVED_STOP_SPEED then
        AIM.current_target = nil
        return
    end

    if AIM.current_target ~= target_loc then
        AIM.current_target = target_loc
        AIM.start_time = common.Time()
    end

    local reaction_s = (ui.settings.reaction or 0) / 1000
    if common.Time() - AIM.start_time < reaction_s then return end

    local eye = Vector3(origin.x, origin.y, origin.z + 64)
    local aim_point = Vector3(target_loc.aim_x, target_loc.aim_y, target_loc.aim_z)
    local target_angles = (aim_point - eye):Angles()

    local current = nil
    pcall(function() current = engine.GetViewAngles() end)
    if not current then return end

    local cur_pitch = current.pitch or current.x or 0
    local cur_yaw = current.yaw or current.y or 0
    local tgt_pitch = target_angles.pitch or target_angles.x or 0
    local tgt_yaw = target_angles.yaw or target_angles.y or 0

    local dp = osnova_angle_diff(cur_pitch, tgt_pitch)
    local dy = osnova_angle_diff(cur_yaw, tgt_yaw)
    local angle_dist = math.sqrt(dp * dp + dy * dy)

    -- smooth approach, but snap exactly onto the aim point once we are
    -- close, so the crosshair ends up dead-centre on it (no residual
    -- offset / "откос" on longer throws)
    local smooth = math.max(0, math.min(100, ui.settings.smooth or 0))
    local alpha = 1 - (smooth / 100) * 0.92
    if angle_dist < 0.8 then alpha = 1 end

    local new_pitch = lerp_angle(cur_pitch, tgt_pitch, alpha)
    local new_yaw = lerp_angle(cur_yaw, tgt_yaw, alpha)

    pcall(function() engine.SetViewAngles(EulerAngles(new_pitch, new_yaw, 0)) end)
end

callbacks.Register("Draw", "osnova_gh_aim", function()
    local ok, err = pcall(osnova_aim_at_point)

end)

-- AUTO THROW + MACRO (mostly unchanged)
local AIM_ANIM_SPEED = 8
local GREEN_SETTLE_TIME = (1 / AIM_ANIM_SPEED) + 0.02
local AUTO_THROW_STOP_SPEED = 5
local NO_AIM_AFTER_THROW = 0.2

local MOVE_DIR_VK = { [2] = AW_VK_W, [3] = AW_VK_S, [4] = AW_VK_A, [5] = AW_VK_D }

local function osnova_throw_release_keys(loc)
    if loc.throw_holding then
        aw_mouse_left(false)
        loc.throw_holding = false
    end

    if loc.throw_move_vk then
        aw_key(loc.throw_move_vk, false)
        loc.throw_move_vk = nil
    end

    if loc.throw_crouching then
        aw_key(AW_VK_CTRL, false)
        loc.throw_crouching = false
    end
end

local RECORD_KEY_VK = { w = AW_VK_W, a = AW_VK_A, s = AW_VK_S, d = AW_VK_D, space = AW_VK_SPACE, ctrl = AW_VK_CTRL }

local function osnova_macro_release_all(loc)
    if not loc.macro_keys_down then return end
    for id, down in pairs(loc.macro_keys_down) do
        if down then
            if id == "attack" then
                aw_mouse_left(false)
            else
                local vk = RECORD_KEY_VK[id]
                if vk then aw_key(vk, false) end
            end
        end
    end
    loc.macro_keys_down = nil
end

-- Find the interpolated camera angle (pitch, yaw) at a given elapsed time.
-- Macro is time-ordered; "look" events are keyframes we lerp between so the
-- replayed camera turns smoothly instead of snapping between samples.
local function osnova_macro_look_at(macro, elapsed_ms)
    local prev_t, prev_p, prev_y = nil, nil, nil
    for k = 1, #macro do
        local ev = macro[k]
        if ev.key == "look" then
            if ev.t <= elapsed_ms then
                prev_t, prev_p, prev_y = ev.t, ev.pitch, ev.yaw
            else
                if prev_t == nil then
                    return ev.pitch, ev.yaw  -- before the first look sample
                end
                local span = ev.t - prev_t
                local f = span > 0 and (elapsed_ms - prev_t) / span or 1
                if f < 0 then f = 0 elseif f > 1 then f = 1 end
                return lerp_angle(prev_p, ev.pitch, f), lerp_angle(prev_y, ev.yaw, f)
            end
        end
    end
    if prev_t ~= nil then
        return prev_p, prev_y  -- after the last look sample: hold final angle
    end
    return nil, nil
end

-- ==================== MOVEMENT HELPER PLAYBACK ====================
local function osnova_movement_release_all(loc)
    if not loc.movement_keys_down then return end
    for id, down in pairs(loc.movement_keys_down) do
        if down then
            local vk = RECORD_KEY_VK[id]
            if vk then aw_key(vk, false) end
        end
    end
    loc.movement_keys_down = nil
end

local function osnova_movement_play_reset(loc)
    osnova_movement_release_all(loc)
    loc.movement_play_active = false
    loc.movement_play_start_at = nil
    loc.movement_play_idx = nil
    loc.movement_aim_since = nil
end

local function osnova_movement_tick_playback(loc, now)
    local macro = loc.movement_macro
    if not macro then return end

    loc.movement_keys_down = loc.movement_keys_down or {}
    local elapsed_ms = (now - loc.movement_play_start_at) * 1000

    loc.movement_play_idx = loc.movement_play_idx or 1
    while loc.movement_play_idx <= #macro and macro[loc.movement_play_idx].t <= elapsed_ms do
        local ev = macro[loc.movement_play_idx]
        if ev.key ~= "look" then
            local vk = RECORD_KEY_VK[ev.key]
            if vk then
                aw_key(vk, ev.down)
                loc.movement_keys_down[ev.key] = ev.down
            end
        end
        loc.movement_play_idx = loc.movement_play_idx + 1
    end

    local ip, iy = osnova_macro_look_at(macro, elapsed_ms)
    if ip ~= nil and iy ~= nil then
        pcall(function() engine.SetViewAngles(EulerAngles(ip, iy, 0)) end)
    end

    if loc.movement_play_idx > #macro then
        osnova_movement_play_reset(loc)
    end
end

local function osnova_movement_playback()
    osnova_update_helper_active()
    if not ui.settings.active then
        for _, md in pairs(ui.map_data) do
            for _, mh in pairs(md.movement_helpers or {}) do
                for _, loc in ipairs(mh.locations or {}) do osnova_movement_play_reset(loc) end
            end
        end
        return
    end

    local action_locs, action_browser, action_id = osnova_get_action_locations()
    if action_browser ~= "movement" then return end
    if not osnova_movement_feature_enabled() then return end

    local local_player = entities.GetLocalPlayer()
    if not local_player or not local_player:IsAlive() then return end

    local now = common.Time()
    local origin = local_player:GetAbsOrigin()
    local speed2d = osnova_get_speed2d(local_player)

    local locs = action_locs

    for _, loc in ipairs(locs) do
        if loc.movement_play_active then
            osnova_movement_tick_playback(loc, now)
        end
    end

    -- do not start another one while one is already replaying
    if osnova_any_macro_playing() then return end

    local target = osnova_select_target(origin)
    if not target or not target.movement_macro then
        for _, loc in ipairs(locs) do
            if not loc.movement_play_active then loc.movement_aim_since = nil end
        end
        return
    end

    if not (target.pos_x and target.pos_y and target.aim_x and target.aim_y and target.aim_z) then return end

    local dist2d = math.sqrt((origin.x - target.pos_x) ^ 2 + (origin.y - target.pos_y) ^ 2)
    local arrived = dist2d <= ARRIVED_DIST and speed2d < ARRIVED_STOP_SPEED
    if not arrived then
        target.movement_aim_since = nil
        return
    end

    local is_aimed = osnova_is_aimed_at(origin, Vector3(target.aim_x, target.aim_y, target.aim_z))
    if not is_aimed then
        target.movement_aim_since = nil
        return
    end

    if not target.movement_aim_since then
        target.movement_aim_since = now
        return
    end

    local reaction_s = (ui.settings.reaction or 0) / 1000
    local wait_time = math.max(reaction_s, GREEN_SETTLE_TIME)
    if now - target.movement_aim_since < wait_time then return end

    target.movement_play_active = true
    target.movement_play_start_at = now
    target.movement_play_idx = 1
    target.movement_keys_down = {}

end

callbacks.Register("Draw", "osnova_mh_playback", function()
    local ok, err = pcall(osnova_movement_playback)

end)
callbacks.Register("Unload", "osnova_mh_playback_unload", function()
    for _, mh in pairs(ui.movement_helpers) do
        for _, loc in ipairs(mh.locations) do osnova_movement_play_reset(loc) end
    end
end)

local function osnova_tick_macro(loc, now)
    local macro = loc.macro
    loc.macro_keys_down = loc.macro_keys_down or {}

    local elapsed_ms = (now - loc.throw_start_at) * 1000

    -- discrete (key) events: fire those whose timestamp has already passed
    loc.macro_idx = loc.macro_idx or 1
    while loc.macro_idx <= #macro and macro[loc.macro_idx].t <= elapsed_ms do
        local ev = macro[loc.macro_idx]
        if ev.key ~= "look" then
            if ev.key == "attack" then
                aw_mouse_left(ev.down)
                loc.macro_keys_down[ev.key] = ev.down
                if not ev.down then
                    loc.no_aim_until = now + NO_AIM_AFTER_THROW
                end
            else
                local vk = RECORD_KEY_VK[ev.key]
                if vk then aw_key(vk, ev.down) end
                loc.macro_keys_down[ev.key] = ev.down
            end
        end
        loc.macro_idx = loc.macro_idx + 1
    end

    -- continuous camera: interpolate between look keyframes for smooth turns
    local ip, iy = osnova_macro_look_at(macro, elapsed_ms)
    if ip ~= nil and iy ~= nil then
        pcall(function() engine.SetViewAngles(EulerAngles(ip, iy, 0)) end)
    end

    if loc.macro_idx > #macro then
        osnova_macro_release_all(loc)
        loc.seq_active = false
        loc.throw_aim_since = nil
        loc.throw_start_at = nil
        loc.macro_idx = nil
    end
end



local function osnova_throw_reset(loc)
    osnova_throw_release_keys(loc)
    osnova_macro_release_all(loc)
    loc.seq_active = false
    loc.throw_aim_since = nil
    loc.throw_start_at = nil
    loc.walk_start_at = nil
    loc.crouch_start_at = nil
    loc.jump_fired = false
    loc.macro_idx = nil
end

local function osnova_tick_sequence(loc, now)
    if loc.macro then
        osnova_tick_macro(loc, now)
        return
    end

    if loc.e_jump and not loc.jump_fired then
        if (now - loc.throw_start_at) * 1000 >= (loc.jump_d or 0) then
            aw_key(AW_VK_SPACE, true)
            aw_key(AW_VK_SPACE, false)
            loc.jump_fired = true
        end
    end

    if loc.throw_move_vk and loc.walk_start_at then
        if (now - loc.walk_start_at) * 1000 >= (loc.run_t or 0) then
            aw_key(loc.throw_move_vk, false)
            loc.throw_move_vk = nil
        end
    end

    if loc.throw_crouching and loc.crouch_start_at then
        if (now - loc.crouch_start_at) * 1000 >= (loc.crouch_t or 0) then
            aw_key(AW_VK_CTRL, false)
            loc.throw_crouching = false
        end
    end

    if loc.throw_holding then
        local held_ms = (now - loc.throw_start_at) * 1000
        if held_ms >= (loc.throw_d or 0) then
            aw_mouse_left(false)
            loc.throw_holding = false
            loc.no_aim_until = now + NO_AIM_AFTER_THROW
        end
    end

    if not loc.throw_holding and not loc.throw_move_vk and not loc.throw_crouching
        and (loc.jump_fired or not loc.e_jump) then
        loc.seq_active = false
        loc.throw_aim_since = nil
        loc.throw_start_at = nil
        loc.walk_start_at = nil
        loc.crouch_start_at = nil
    end
end

local function osnova_auto_throw()
    osnova_update_helper_active()
    if not ui.settings.active then
        for _, md in pairs(ui.map_data) do
            for _, group in pairs(md.groups or {}) do
                for _, loc in ipairs(group.locations or {}) do
                    osnova_throw_reset(loc)
                end
            end
        end
        return
    end

    local local_player = entities.GetLocalPlayer()
    if not local_player or not local_player:IsAlive() then return end

    local menu_is_open = ui.menu_active
    if menu_is_open == nil then
        pcall(function() menu_is_open = gui.Reference("Menu"):IsActive() end)
    end

    local speed2d = osnova_get_speed2d(local_player)
    local is_stopped = speed2d < AUTO_THROW_STOP_SPEED

    local origin = local_player:GetAbsOrigin()
    local now = common.Time()

    if not osnova_is_holding_grenade() then
        for _, md in pairs(ui.map_data) do
            for _, group in pairs(md.groups or {}) do
                for _, loc in ipairs(group.locations or {}) do
                    osnova_throw_reset(loc)
                end
            end
        end
        return
    end

    local grenade_def = osnova_canonical_grenade_def(osnova_active_grenade_def())
    local locs = osnova_get_locations_for(ui.current_map, "group", grenade_def)

    for _, loc in ipairs(locs) do
        if loc.seq_active then
            osnova_tick_sequence(loc, now)
        end
    end

    -- Only ONE location can be armed / played at a time: the one we're looking
    -- at inside the FOV cone. Everything else (including the "newest" spot or a
    -- closer ground spot) is reset, so we never throw / play back the wrong one.
    local target = osnova_select_target(origin)

    local best_loc = nil

    for _, loc in ipairs(locs) do
        if loc.seq_active then
            -- already playing; ticked above, leave it alone
        elseif loc == target and (loc.macro or loc.e_throw)
            and loc.aim_x and loc.aim_y and loc.aim_z
            and loc.pos_x and loc.pos_y then
            local player_dist_2d = math.sqrt((origin.x - loc.pos_x) ^ 2 + (origin.y - loc.pos_y) ^ 2)
            local locked_out = loc.no_aim_until and now < loc.no_aim_until
            local has_arrived = player_dist_2d <= ARRIVED_DIST and speed2d < ARRIVED_STOP_SPEED

            if locked_out or not has_arrived then
                osnova_throw_reset(loc)
            else
                local is_aimed = osnova_is_aimed_at(origin, Vector3(loc.aim_x, loc.aim_y, loc.aim_z))
                if is_aimed then
                    best_loc = loc
                else
                    osnova_throw_reset(loc)
                end
            end
        else
            osnova_throw_reset(loc)
        end
    end

    for _, loc in ipairs(locs) do
        if loc ~= best_loc and not loc.seq_active and loc.throw_aim_since then
            osnova_throw_reset(loc)
        end
    end

    if best_loc then
        local loc = best_loc

        if not loc.throw_aim_since then
            loc.throw_aim_since = now
        end

        local reaction_s = (ui.settings.reaction or 0) / 1000
        local wait_time = math.max(reaction_s, GREEN_SETTLE_TIME)
        local settled = (now - loc.throw_aim_since) >= wait_time

        if settled then
            loc.seq_active = true
            loc.throw_start_at = now

            if loc.macro then
                loc.macro_idx = 1
                loc.macro_keys_down = {}
            else
                loc.jump_fired = false
                aw_mouse_left(true)
                loc.throw_holding = true

                if loc.e_crouch then
                    aw_key(AW_VK_CTRL, true)
                    loc.throw_crouching = true
                    loc.crouch_start_at = now
                end

                if loc.e_walk and (loc.m_dir or 1) > 1 then
                    local vk = MOVE_DIR_VK[loc.m_dir]
                    if vk then
                        aw_key(vk, true)
                        loc.throw_move_vk = vk
                        loc.walk_start_at = now
                    end
                end
            end
        end
    end
end

callbacks.Register("Draw", "osnova_gh_autothrow", function()
    local ok, err = pcall(osnova_auto_throw)

end)

local function osnova_gh_autothrow_cleanup()
    for _, md in pairs(ui.map_data) do
        for _, group in pairs(md.groups or {}) do
            for _, loc in ipairs(group.locations or {}) do
                osnova_throw_release_keys(loc)
                osnova_macro_release_all(loc)
            end
        end
    end
end

callbacks.Register("Unload", "osnova_gh_autothrow_unload", osnova_gh_autothrow_cleanup)

