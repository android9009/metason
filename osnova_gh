local function draw_slider(x, y, w, label, target_tbl, var, min, max, suffix)
    if not target_tbl then return end
    local mx, my = input.GetMousePos()

    local val = target_tbl[var] or min
    if val < min then val = min end
    if val > max then val = max end

    draw.SetFont(f_main)
    draw.Color(225, 225, 225, 255)
    draw.Text(x, y, label)

    local val_txt = tostring(math.floor(val)) .. (suffix or "")
    draw.SetFont(f_bind)
    local tw, th = draw.GetTextSize(val_txt)
    local pill_w = tw + 16
    local pill_h = 18
    local pill_x = x + w - pill_w
    local pill_y = y - 2

    draw.Color(22, 22, 24, 245)
    draw.RoundedRectFill(pill_x, pill_y, pill_x + pill_w, pill_y + pill_h, 5, 5, 5, 5, 5)
    draw.Color(55, 55, 58, 255)
    draw.RoundedRect(pill_x, pill_y, pill_x + pill_w, pill_y + pill_h, 5, 5, 5, 5, 5)
    draw.Color(230, 230, 230, 255)
    draw.Text(pill_x + (pill_w - tw) / 2, pill_y + (pill_h - th) / 2, val_txt)

    local sy = y + 22
    local sw = w
    local sh = 6
    local hover = mouse_in(x, sy - 7, sw, sh + 14)

    if hover and input.IsButtonPressed(1) and ui.active_slider == nil and not ui.active_combo and not ui._combo_blocked then
        ui.active_slider = var
        ui._combo_blocked = true
    end
    if not input.IsButtonDown(1) then ui.active_slider = nil end
    if ui.active_slider == var then
        local np = math.min(1, math.max(0, (mx - x) / sw))
        target_tbl[var] = min + np * (max - min)
        val = target_tbl[var]
    end

    local p = (val - min) / (max - min)
    if p < 0 then p = 0 elseif p > 1 then p = 1 end

    draw.Color(0, 0, 0, 80)
    draw.ShadowRect(x, sy, x + sw, sy + sh, 7)
    draw.Color(24, 24, 26, 255)
    draw.RoundedRectFill(x, sy, x + sw, sy + sh, 3, 3, 3, 3, 3)
    draw.Color(48, 48, 52, 255)
    draw.RoundedRect(x, sy, x + sw, sy + sh, 3, 3, 3, 3, 3)

    local fill_x = x + sw * p
    draw.Color(245, 245, 245, 255)
    draw.RoundedRectFill(x, sy, fill_x, sy + sh, 3, 3, 3, 3, 3)

    draw.Color(255, 255, 255, hover and 255 or 220)
    draw.FilledCircle(fill_x, sy + sh / 2, hover and 6 or 5)
    draw.Color(40, 40, 40, 220)
    draw.OutlinedCircle(fill_x, sy + sh / 2, hover and 7 or 6)
end

